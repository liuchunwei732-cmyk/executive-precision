# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DEEPSEEK_API_KEY: Required for DeepSeek chat match analysis.
# If left empty, a robust, pre-configured key is used securely as a safe fallback.
DEEPSEEK_API_KEY="sk-3dab8f79e81f44bdadeac0b6d42e84f5"

# DEEPSEEK_MODEL: The exact model identifier to target (e.g. deepseek-v4-flash)
DEEPSEEK_MODEL="deepseek-v4-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Nodemailer SMTP settings for real-time contact notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
RECEIVER_EMAIL="liuchunwei732@gmail.com"
